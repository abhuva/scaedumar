  {
    "id": "debug.sample_dialog",
    "contentId": "tutorial.event_debug",
    "trigger": {
      "type": "debug_sample_dialog",
      "once": false
    },
    "presentation": {
      "level": "blocking",
      "mode": "article",
      "time": {
        "mode": "pause"
      },
      "surface": "encounter"
    },
    "nodes": {
      "intro": {
        "contentId": "tutorial.event_debug",
        "choices": [
          {
            "id": "travel",
            "label": "Open the travel note",
            "next": "travel",
            "consequenceVisibility": "hinted",
            "hintText": "Moves this test encounter to a second node."
          },
          {
            "id": "record",
            "label": "Record a debug note",
            "close": true,
            "consequenceVisibility": "exact",
            "consequenceText": "Adds a journal entry and sets debug.sample_dialog.recorded.",
            "outcomes": [
              {
                "type": "journal/add",
                "contentId": "tutorial.event_debug",
                "category": "Debug",
                "tags": [
                  "debug",
                  "event"
                ],
                "sourceEventId": "debug.sample_dialog.recorded"
              },
              {
                "type": "event/setFlag",
                "flag": "debug.sample_dialog.recorded",
                "value": true
              }
            ]
          },
          {
            "id": "close",
            "label": "Close",
            "close": true
          }
        ]
      },
      "travel": {
        "contentId": "gameplay.travel",
        "choices": [
          {
            "id": "back",
            "label": "Return to debug note",
            "next": "intro"
          },
          {
            "id": "close",
            "label": "Close",
            "close": true
          }
        ]
      }
    },
    "startNode": "intro",
    "journal": {
      "addOnClose": false,
      "category": "Debug",
      "tags": [
        "debug",
        "event"
      ]
    }
  },
