    "id": "debug.sample_dialog",
    "contentId": "tutorial.event_debug",
    "trigger": {
      "type": "debug_sample_dialog",
      "once": false
    },
    "presentation": {
      "level": "blocking",
      "mode": "article",
      "time": {
        "mode": "pause"
      }
    },
    "nodes": {
      "intro": {
        "contentId": "tutorial.event_debug",
        "choices": [
          {
            "id": "travel",
            "label": "Continue to travel page",
            "next": "travel",
            "consequenceVisibility": "hinted",
            "hintText": "Opens a second dialog node."
          },
          {
            "id": "record",
            "label": "Record debug journal entry",
            "close": true,
            "consequenceVisibility": "exact",
            "consequenceText": "Adds a journal entry and sets debug.sample_dialog.recorded.",
            "outcomes": [
              {
                "type": "journal/add",
                "contentId": "tutorial.event_debug",
                "category": "Debug",
                "tags": ["debug", "event"],
                "sourceEventId": "debug.sample_dialog.recorded"
              },
              {
                "type": "event/setFlag",
                "flag": "debug.sample_dialog.recorded",
                "value": true
              }
            ]
          },
          {
            "id": "close",
            "label": "Close",
            "close": true
          }
        ]
      },
      "travel": {
        "contentId": "gameplay.travel",
        "choices": [
          {
            "id": "back",
            "label": "Back to debug page",
            "next": "intro"
          },
          {
            "id": "close",
            "label": "Close",
            "close": true
          }
        ]
      }
    },
    "startNode": "intro",
    "journal": {
      "addOnClose": false,
      "category": "Debug",
      "tags": ["debug", "event"]
    }
  },
