{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capability with minimal core permissions for invoke + window lifecycle.",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:app:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-is-fullscreen",
    "core:window:allow-set-fullscreen",
    "core:webview:default"
  ]
}
